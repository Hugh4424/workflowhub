+        }
+        $reqStream = $webReq.GetRequestStream()
+        $reqStream.Write($bodyBytes, 0, $bodyBytes.Length)
+        $reqStream.Close()
+        $webResp = $webReq.GetResponse()
+        $respStream = $webResp.GetResponseStream()
