+        Write-Error "API Error: $errMsg"
+        exit 1
+    }
+
+    $result = $null
+    try { $result = $resp.result } catch { $result = $resp }
+
+    if ($result -and $result.content) {
+        foreach ($item in $result.content) {
+            if ($item.type -eq "text") {
+                return $item.text
+            }
+        }
+    }
